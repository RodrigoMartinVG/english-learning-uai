{
  "name": "english-learning-uai",
  "version": "0.0.0",
  "description": "App de entrenamiento auditivo y oral para Ingles I (UAI)",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "validate": "tsx scripts/validate-content.ts",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run test && npm run validate",
    "build:audio": "tsx scripts/build-audio.ts",
    "flags": "tsx scripts/review-flags.ts",
    "audit": "tsx scripts/audit-content.ts",
    "audio:review": "tsx scripts/build-audio-review.ts",
    "build:ipa": "tsx scripts/build-ipa.ts",
    "test": "tsx --test tests/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RodrigoMartinVG/english-learning-uai.git"
  },
  "type": "module",
  "bugs": {
    "url": "https://github.com/RodrigoMartinVG/english-learning-uai/issues"
  },
  "homepage": "https://github.com/RodrigoMartinVG/english-learning-uai#readme",
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "kokoro-js": "^1.2.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "private": true
}
