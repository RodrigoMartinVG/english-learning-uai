node_modules/
dist/
.vite/

# Material oficial de la cátedra (UAI). NO se versiona: tiene derechos y no es nuestro
# para redistribuir. Vive solo localmente y alimenta el pipeline de extracción.
# Ver material/README.md para saber qué archivos poner ahí.
material/*.pdf

# Audio generado por scripts/build-audio.ts — derivado de content/, no fuente de verdad.
# Se regenera con `npm run build:audio`. El manifest SÍ se versiona (es el cache de hashes).
#
# OJO: tiene que ser "public/audio/*" y NO "public/audio/". Con la barra final git
# excluye el directorio entero y ni siquiera desciende, así que el "!" de abajo nunca
# llega a aplicarse y el manifest quedaría ignorado en silencio.
public/audio/*
!public/audio/audio-manifest.json

# Credenciales del proveedor TTS. NUNCA commitear.
.env
.env.local

# Artefactos temporales del pipeline
scripts/.cache/
*.log

.DS_Store
Thumbs.db
public/audio-review.html
